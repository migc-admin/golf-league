# Supabase (publishable — safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# All other secrets (API keys, service role key, Stripe secret, webhook secret)
# are stored as Supabase Edge Function secrets — never in this file.
# Set them with: supabase secrets set KEY=value
